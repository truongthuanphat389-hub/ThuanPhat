        "import heapq\n",
        "def get_manhattan_distance(state; goal):\n",
        "  distance = 0\n",
        "  for i in range(16)\n",
        "      if state[i] != 0\n",
        "          target_idx = goal.index(state[i])\n",
        "          distance += abs(i // 4 - target_idx // 4) + abs(i % 4 - target_idx % 4)\n",
        "  return distance\n",
        "def solve_15_puzzle(start_state, goal_state):\n",
        "  pq = [(get_manhattan_distance(start_state, goal_state), start_state, [])]\n",
